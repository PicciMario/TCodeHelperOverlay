<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="TCodeLaunchpad.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="TCode Launchpad"
    WindowStyle="None"
    ResizeMode="NoResize"
    AllowsTransparency="True"
    Background="#00000000"
    ShowInTaskbar="False"
    Topmost="True"
    Width="900"
    Height="560">
    <Grid>
        <Grid.Background>
            <RadialGradientBrush GradientOrigin="0.5,0.35" Center="0.5,0.45" RadiusX="0.9" RadiusY="0.9">
                <GradientStop Color="#9E133B13" Offset="0" />
                <GradientStop Color="#7A092409" Offset="0.42" />
                <GradientStop Color="#A0040904" Offset="1" />
            </RadialGradientBrush>
        </Grid.Background>

        <StackPanel
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,18,24,0"
            IsHitTestVisible="False">
            <TextBlock
                Text="TCode Helper"
                FontSize="14"
                FontWeight="Bold"
                FontFamily="Cascadia Mono,Consolas"
                Foreground="#D194FF94"
                HorizontalAlignment="Right" />
            <TextBlock
                Text="By Mario v0.3.1"
                FontFamily="Cascadia Mono,Consolas"
                FontSize="10"
                Foreground="#8A84D784"
                HorizontalAlignment="Right" />
        </StackPanel>

        <Border
            x:Name="SearchHost"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Width="860"
            Margin="24"
            CornerRadius="8"
            BorderBrush="#7A6EE96E"
            BorderThickness="1"
            Background="#8A081708"
            Padding="20">
            <TextBox
                x:Name="SearchBox"
                TextChanged="SearchBox_TextChanged"
                PreviewKeyDown="SearchBox_KeyDown"
                GotKeyboardFocus="SearchBox_GotKeyboardFocus"
                Height="42"
                HorizontalAlignment="Stretch"
                VerticalContentAlignment="Center"
                FontSize="16"
                FontFamily="Cascadia Mono,Consolas"
                Padding="12,6"
                BorderBrush="#8A69E369"
                BorderThickness="1"
                Background="#D4041004"
                CaretBrush="#E8A8FFA8"
                SelectionBrush="#AA2A7D2A"
                Foreground="#F3AEFFAE"
                ToolTip="Type code, name, or keyword" />
        </Border>

        <Border
            x:Name="ResultsHost"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Width="860"
            Margin="24,76,24,24"
            CornerRadius="8"
            BorderBrush="#7A6EE96E"
            BorderThickness="1"
            Background="#8A081708"
            Padding="12"
            Visibility="Collapsed"
            Height="420">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ListBox
                    x:Name="ResultsList"
                    Grid.Column="0"
                    PreviewKeyDown="ResultsList_KeyDown"
                    SelectionChanged="ResultsList_SelectionChanged"
                    BorderThickness="0"
                    Background="Transparent"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    Foreground="#F3AEFFAE"
                    FontFamily="Cascadia Mono,Consolas">
                    <ListBox.Resources>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,1" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style x:Key="SlimThumbStyle" TargetType="Thumb">
                            <Setter Property="Background" Value="#AA6FEB6F" />
                            <Setter Property="BorderBrush" Value="#CC143114" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4" />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style TargetType="ScrollBar">
                            <Setter Property="Width" Value="8" />
                            <Setter Property="Margin" Value="4,2,2,2" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ScrollBar">
                                        <Grid Width="{TemplateBinding Width}">
                                            <Border
                                                Background="#33030B03"
                                                CornerRadius="4" />
                                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                <Track.DecreaseRepeatButton>
                                                    <RepeatButton
                                                        Command="ScrollBar.PageUpCommand"
                                                        Opacity="0"
                                                        IsHitTestVisible="False" />
                                                </Track.DecreaseRepeatButton>
                                                <Track.Thumb>
                                                    <Thumb Style="{StaticResource SlimThumbStyle}" />
                                                </Track.Thumb>
                                                <Track.IncreaseRepeatButton>
                                                    <RepeatButton
                                                        Command="ScrollBar.PageDownCommand"
                                                        Opacity="0"
                                                        IsHitTestVisible="False" />
                                                </Track.IncreaseRepeatButton>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="Orientation" Value="Horizontal">
                                    <Setter Property="Height" Value="8" />
                                    <Setter Property="Width" Value="Auto" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Resources>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border
                                x:Name="RowGlowBorder"
                                Margin="4"
                                Padding="4"
                                CornerRadius="4"
                                BorderThickness="1"
                                BorderBrush="#00000000"
                                Background="#00000000"
                                Opacity="1">
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Text="{Binding Code}"
                                        FontWeight="Bold"
                                        FontFamily="Cascadia Mono,Consolas"
                                        Margin="0,0,8,0"
                                        Foreground="#F3BCFFBC" />
                                    <StackPanel Grid.Column="1" Orientation="Vertical">
                                        <TextBlock
                                            Text="{Binding Description}"
                                            TextWrapping="Wrap"
                                            Foreground="#EBAAFFAA" />
                                        <TextBlock
                                            Text="{Binding Module}"
                                            FontSize="12"
                                            Foreground="#AD79CD79" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                    <Setter TargetName="RowGlowBorder" Property="BorderBrush" Value="#FF7FFF7F" />
                                    <Setter TargetName="RowGlowBorder" Property="Background" Value="#5A1D6B1D" />
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard Name="SelectionPulseStoryboard">
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetName="RowGlowBorder" Storyboard.TargetProperty="Opacity" From="0.45" To="1" Duration="0:0:0.5" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="SelectionPulseStoryboard" />
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Column="1" Background="#6662C762" Width="1" HorizontalAlignment="Center" />

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox
                        x:Name="DetailsTextBox"
                        Grid.Row="0"
                        PreviewKeyDown="DetailsTextBox_KeyDown"
                        IsReadOnly="True"
                        TextWrapping="Wrap"
                        AcceptsReturn="True"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        BorderThickness="0"
                        Background="Transparent"
                        Foreground="#EAAEFFAE"
                        FontFamily="Cascadia Mono,Consolas"
                        FontSize="13"
                        Padding="10,6" />

                    <TextBox
                        x:Name="DebugTextBox"
                        Grid.Row="1"
                        PreviewKeyDown="DetailsTextBox_KeyDown"
                        IsReadOnly="True"
                        TextWrapping="Wrap"
                        AcceptsReturn="True"
                        VerticalScrollBarVisibility="Disabled"
                        HorizontalScrollBarVisibility="Disabled"
                        BorderThickness="0"
                        Background="Transparent"
                        Foreground="#B56DBE6D"
                        FontFamily="Cascadia Mono,Consolas"
                        FontSize="11"
                        Padding="10,4,10,8"
                        Margin="0,4,0,0" />
                </Grid>
            </Grid>
        </Border>

        <Border IsHitTestVisible="False" Opacity="0.22">
            <Border.Background>
                <VisualBrush TileMode="Tile" Viewport="0,0,1,4" ViewportUnits="Absolute">
                    <VisualBrush.Visual>
                        <Rectangle Width="1" Height="4" Fill="#12000000" />
                    </VisualBrush.Visual>
                </VisualBrush>
            </Border.Background>
        </Border>

        <TextBlock
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="24"
            Foreground="#9E8DDB8D"
            FontSize="10"
            FontFamily="Cascadia Mono,Consolas"
            TextWrapping="Wrap"
            TextAlignment="Right"
            MaxWidth="760">
            <Run Text="Cache: " />
            <Run x:Name="CachePathRun" Text="(initializing...)" />
            <Run Text=" | Age: " />
            <Hyperlink Click="CacheAgeHyperlink_Click" ToolTip="Click to refresh now" Foreground="#D6A6FFA6">
                <Run x:Name="CacheAgeRun" Text="n/a" />
            </Hyperlink>
        </TextBlock>
    </Grid>
</Window>
